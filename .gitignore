# --- GIS & Large Data Files ---
# We ignore these because they should be fetched via the pipeline 
# or hosted on a CDN/PMTiles server, not stored in Git history.
*.geojson
*.gpkg
*.shp
*.dbf
*.prj
*.shx
*.csv
*.parquet
*.geoparquet

# --- DuckDB & Databases ---
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite-journal

# --- Map Tiles ---
# PMTiles archives can be hundreds of MBs. Do not commit.
*.pmtiles
# MBTiles (if used)
*.mbtiles

# --- Documentation ---
# If using Mintlify or Fumadocs local previews
.mintlify
.fumadocs

# --- Testing ---
/coverage
.nyc_output
playwright-report/
test-results/